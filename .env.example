# Backend
NODE_ENV=development
HOST=0.0.0.0
PORT=4000
CORS_ORIGIN=*

# Base de dados operacional SAR (PostgreSQL/PostGIS)
# Exemplo para Docker Compose local (ver docker-compose.yml):
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_SSL=false
POSTGRES_DB=sar_desaparecidos
POSTGRES_USER=sar_app
POSTGRES_PASSWORD=change_me_dev_password
DATABASE_URL=postgres://sar_app:change_me_dev_password@localhost:5432/sar_desaparecidos
# Para um provedor gerido (ex.: Supabase), substitua pelos valores da sua própria instância:
# DATABASE_URL=postgresql://postgres:<sua_password>@<seu_host>.supabase.co:5432/postgres
# Fonte de leitura dos endpoints oficiais: csv (padrão) ou db.
# Use db apenas depois de executar db:migrate e db:import-csv.
DATA_SOURCE=db
# Escrita paralela em PostGIS mantendo CSV como compatibilidade.
# Também fica ativa quando DATA_SOURCE=db.
DB_DUAL_WRITE=true

# Segurança
# Gere um valor longo e aleatório antes de usar fora de desenvolvimento local.
JWT_SECRET=change_me_to_a_long_random_secret

# Geocodificação (Nominatim/OpenStreetMap exige um contacto identificável no User-Agent)
NOMINATIM_CONTACT_EMAIL=contact@example.com

# LLM / IA
GROQ_API_KEY=

# Email / SMTP
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
EMAIL_DESTINATARIOS=example@example.com

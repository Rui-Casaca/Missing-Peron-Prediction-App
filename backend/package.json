{
  "name": "gnr-sistema-desaparecidos-backend",
  "version": "1.0.0",
  "description": "Sistema de análise e previsão para pessoas desaparecidas - Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "monitor": "node monitorCsv.js",
    "typecheck": "tsc --noEmit",
    "test:ts": "tsx --test \"test/**/*.test.ts\"",
    "test": "node --test",
    "db:migrate": "node db/migrate.js",
    "db:import-csv": "node scripts/importOfficialCsvToDb.js",
    "db:import-csv:dry-run": "node scripts/importOfficialCsvToDb.js --dry-run",
    "db:export-csv": "node scripts/exportOfficialCsvFromDb.js",
    "db:backfill-events": "node scripts/backfillCaseCreatedEvents.js",
    "db:backfill-events:dry-run": "node scripts/backfillCaseCreatedEvents.js --dry-run",
    "seed:demo-admin": "node scripts/seedDemoAdmin.js",
    "install-deps": "npm install express cors csv-parser csv-writer nodemon bcrypt jsonwebtoken yargs"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "chokidar": "^3.5.3",
    "cors": "^2.8.5",
    "csv-parse": "^5.4.0",
    "csv-parser": "^3.2.0",
    "csv-writer": "^1.6.0",
    "dotenv": "^16.3.1",
    "express": "^4.21.2",
    "fast-xml-parser": "^5.8.0",
    "groq-sdk": "^0.32.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^2.6.7",
    "nodemailer": "^6.9.4",
    "openai": "^5.21.0",
    "pdfkit": "^0.13.0",
    "pg": "^8.13.1",
    "yargs": "^17.7.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.2",
    "@types/node-fetch": "^2.6.13",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.20.0",
    "@types/yargs": "^17.0.35",
    "nodemon": "^3.1.10",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
